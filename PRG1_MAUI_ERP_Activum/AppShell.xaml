<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="PRG1_MAUI_ERP_Activum.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:PRG1_MAUI_ERP_Activum.View"
    Shell.FlyoutBehavior="Flyout">

    <Shell.FlyoutContent>
        <local:CustomFlyoutView/>
    </Shell.FlyoutContent>

    <FlyoutItem Title="Hem">
        <Tab>
            <ShellContent Route="MainPage" ContentTemplate="{DataTemplate local:MainPage}"></ShellContent>
        </Tab>
    </FlyoutItem>

    <FlyoutItem Title="Kunder">
        <Tab>
            <ShellContent  Route="CustomersPage" ContentTemplate="{DataTemplate local:CustomersPage}"></ShellContent>
        </Tab>
    </FlyoutItem>

    <FlyoutItem Title="Försäkringar">
        <Tab>
            <ShellContent Route="InsurancePage" ContentTemplate="{DataTemplate local:InsurancePage}"></ShellContent>
        </Tab>
    </FlyoutItem>

</Shell>