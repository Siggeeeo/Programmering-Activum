<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="ActivumBlueGreen">#134f5c</Color>
    <Color x:Key="ActivumWhite">#FFFFFF</Color>
    <Color x:Key="ActivumBlack">#000000</Color>
    <Color x:Key="ActivumGray">#666666</Color>
    
    <Color x:Key="Primary">#134f5c</Color>
    <Color x:Key="PageBackground">#FFFFFF</Color>
    <Color x:Key="PrimaryText">#000000</Color>
    <Color x:Key="SecondaryText">#666666</Color>
    
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="Gray100">#F5F5F5</Color>
    <Color x:Key="Gray200">#E5E7EB</Color>
    <Color x:Key="Gray300">#D1D5DB</Color>
    <Color x:Key="Gray400">#9CA3AF</Color>
    <Color x:Key="Gray500">#6B7280</Color>
    <Color x:Key="Gray600">#4B5563</Color>
    <Color x:Key="Gray900">#111827</Color>
    <Color x:Key="Gray950">#0B0F16</Color>
    <Color x:Key="MidnightBlue">#001f3f</Color>
    <Color x:Key="Magenta">#FF00A8</Color>
    <Color x:Key="OffBlack">#0A0A0A</Color>
    <Color x:Key="PrimaryDark">#0f3a43</Color>
    <Color x:Key="PrimaryDarkText">#E6F7F6</Color>
    <Color x:Key="Secondary">#FF6B6B</Color>
    <Color x:Key="SecondaryDarkText">#F3E9E9</Color>
    
    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource PrimaryText}, Dark={StaticResource White}}"/>
    </Style>
</ResourceDictionary>