<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:sys="clr-namespace:System;assembly=netstandard"
             x:Class="PRG1_MAUI_ERP_Activum.View.MainPage"
             Title="Hem"
             BackgroundColor="White">

    <ScrollView>
        <VerticalStackLayout Spacing="25" Padding="20">
            <Label Text="Välkommen till Activum"
                   FontSize="30"
                   HorizontalOptions="Center"
                   TextColor="{StaticResource ActivumBlueGreen}"
                   Margin="0,20,0,10"></Label>

            <Label Text="Välj ett val nedan för att starta"
                   FontSize="17"
                   HorizontalOptions="Center"
                   TextColor="{StaticResource SecondaryText}"></Label>

            <Grid ColumnDefinitions="*,*" RowDefinitions="100, 100" RowSpacing="15" ColumnSpacing="15" Margin="0,20,0,0">

                <Button Grid.Row="0" Grid.Column="0"
                        Text="Kunder"
                        FontSize="17"
                        BackgroundColor="{StaticResource ActivumBlueGreen}" TextColor="{StaticResource ActivumWhite}"
                        Clicked="OnNavigateToCustomers"></Button>

                <Button Grid.Row="0" Grid.Column="1"
                        Text="Försäkringar"
                        FontSize="17"
                        BackgroundColor="{StaticResource ActivumBlueGreen}" TextColor="{StaticResource ActivumWhite}"
                        Clicked="OnNavigateToInsurance"></Button>
                
                <Button Grid.Row="1" Grid.Column="0"
                        Text="Traktamente"
                        FontSize="17"
                        BackgroundColor="{StaticResource ActivumBlueGreen}" TextColor="{StaticResource ActivumWhite}"
                        Clicked="OnNavigateToPerDiem"></Button>
                
                <Button Grid.Row="1" Grid.Column="1"
                        Text="Lön och Bonus"
                        FontSize="17"
                        BackgroundColor="{StaticResource ActivumBlueGreen}" TextColor="{StaticResource ActivumWhite}"
                        Clicked="OnNavigateToSalary"></Button>

            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
