<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PRG1_MAUI_ERP_Activum.View.AboutPage"
             Title="Om Appen">

    <ContentPage.Resources>
        <Color x:Key="ActivumBlack">#000000</Color>
        <Color x:Key="ActivumWhite">#FFFFFF</Color>
        <Color x:Key="ActivumGray">#666666</Color>
        <Color x:Key="ActivumBlueGreen">#134f5c</Color>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, *, Auto" Padding="20" BackgroundColor="{StaticResource ActivumWhite}">

        <VerticalStackLayout Grid.Row="0" Spacing="10" Margin="0,0,0,20">
            <Label Text="Om Activum"
                   FontSize="32"
                   FontAttributes="Bold"
                   TextColor="{StaticResource ActivumBlueGreen}"
                   FontFamily="Verdana"
                   HorizontalOptions="Center"
                   
                   />
            <BoxView HeightRequest="2"
                     Color="{StaticResource ActivumBlueGreen}"
                     WidthRequest="150"
                     HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="25" VerticalOptions="Center">

                <Label Text="Din plattform för smidig hantering av försäkringar, traktamenten och lönerapportering."
                       HorizontalTextAlignment="Center"
                       FontFamily="Verdana"
                       FontSize="16"
                       TextColor="{StaticResource ActivumBlack}"/>

                <VerticalStackLayout Spacing="5" Margin="0, 20, 0, 0">
                    <Label Text="Utvecklad av:"
                           HorizontalTextAlignment="Center"
                          
                           FontSize="14"
                           TextColor="{StaticResource ActivumBlack}"
                           FontFamily="Verdana"
                           
                           />

                    <Label Text="Kristian &amp; Sigge"
                           HorizontalTextAlignment="Center"
                           
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="{StaticResource ActivumBlueGreen}"
                           FontFamily="Verdana"
                           />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <VerticalStackLayout Grid.Row="2" Spacing="2" HorizontalOptions="Center">
            <Label Text="Version 1.0.0"
                   FontSize="12"
                   TextColor="{StaticResource ActivumBlack}"
                   HorizontalOptions="Center"
                   FontFamily="Verdana"
                   />
            <Label Text="© 2026 ACTIVUM Försäkring AB"
                   FontSize="12"
                   TextColor="{StaticResource ActivumGray}"
                   HorizontalOptions="Center"
                   FontFamily="Verdana"
                   />
        </VerticalStackLayout>

    </Grid>
</ContentPage>