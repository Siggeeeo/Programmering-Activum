<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PRG1_MAUI_ERP_Activum.View.CalculatorPage"
             Title="Kalkylator"
             BackgroundColor="{StaticResource PageBackground}">

    <ContentPage.Resources>
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="HeightRequest" Value="70" />
            <Setter Property="FontFamily" Value="Verdana" />
        </Style>
    </ContentPage.Resources>

    <VerticalStackLayout Padding="25" Spacing="20" VerticalOptions="Center">

        <Frame BackgroundColor="{StaticResource Gray100}" 
               CornerRadius="12" 
               Padding="20" 
               BorderColor="Transparent">
            <Label x:Name="DisplayLabel" 
                   Text="0" 
                   FontSize="50" 
                   FontFamily="Verdana"
                   HorizontalTextAlignment="End" 
                   TextColor="{StaticResource PrimaryText}"/>
        </Frame>

        <Grid RowDefinitions="Auto,Auto,Auto,Auto" 
              ColumnDefinitions="*,*,*,*" 
              RowSpacing="10" 
              ColumnSpacing="10">

            <Button Text="7" Grid.Row="0" Grid.Column="0" Clicked="OnNumberClicked" FontFamily="Verdana" BackgroundColor="{StaticResource Gray500}" TextColor="{StaticResource PrimaryText}"/>
            <Button Text="8" Grid.Row="0" Grid.Column="1" FontFamily="Verdana" Clicked="OnNumberClicked" BackgroundColor="{StaticResource Gray500}" TextColor="{StaticResource PrimaryText}"/>
            <Button Text="9" Grid.Row="0" Grid.Column="2" Clicked="OnNumberClicked" BackgroundColor="{StaticResource Gray500}" TextColor="{StaticResource PrimaryText}" FontFamily="Verdana"/>
            <Button Text="/" Grid.Row="0" Grid.Column="3" Clicked="OnOperatorClicked" BackgroundColor="{StaticResource ActivumBlueGreen}" TextColor="White" FontFamily="Verdana" />

            <Button Text="4" Grid.Row="1" Grid.Column="0" Clicked="OnNumberClicked" BackgroundColor="{StaticResource Gray500}" FontFamily="Verdana" TextColor="{StaticResource PrimaryText}"/>
            <Button Text="5" Grid.Row="1" Grid.Column="1" Clicked="OnNumberClicked" BackgroundColor="{StaticResource Gray500}" TextColor="{StaticResource PrimaryText}" FontFamily="Verdana"/>
            <Button Text="6" Grid.Row="1" Grid.Column="2" FontFamily="Verdana" Clicked="OnNumberClicked" BackgroundColor="{StaticResource Gray500}" TextColor="{StaticResource PrimaryText}"/>
            <Button Text="x" Grid.Row="1" Grid.Column="3" Clicked="OnOperatorClicked" BackgroundColor="{StaticResource ActivumBlueGreen}" TextColor="White" FontFamily="Verdana" />

            <Button Text="1" Grid.Row="2" Grid.Column="0" Clicked="OnNumberClicked" BackgroundColor="{StaticResource Gray500}" TextColor="{StaticResource PrimaryText}" FontFamily="Verdana"/>
            <Button Text="2" Grid.Row="2" Grid.Column="1" FontFamily="Verdana" Clicked="OnNumberClicked" BackgroundColor="{StaticResource Gray500}" TextColor="{StaticResource PrimaryText}"/>
            <Button Text="3" Grid.Row="2" Grid.Column="2" Clicked="OnNumberClicked" BackgroundColor="{StaticResource Gray500}" FontFamily="Verdana" TextColor="{StaticResource PrimaryText}"/>
            <Button Text="-" Grid.Row="2" Grid.Column="3" Clicked="OnOperatorClicked" BackgroundColor="{StaticResource ActivumBlueGreen}" TextColor="White" FontFamily="Verdana" />

            <Button Text="X" Grid.Row="3" Grid.Column="0" Clicked="OnClearClicked" BackgroundColor="{StaticResource ActivumBlack}" TextColor="White" FontFamily="Verdana"/>
            <Button Text="0" Grid.Row="3" Grid.Column="1" Clicked="OnNumberClicked" BackgroundColor="{StaticResource Gray500}" FontFamily="Verdana" TextColor="{StaticResource PrimaryText}"/>
            <Button Text="=" Grid.Row="3" Grid.Column="2" Clicked="OnCalculateClicked" BackgroundColor="{StaticResource ActivumBlueGreen}" TextColor="White" FontFamily="Verdana"/>
            <Button Text="+" Grid.Row="3" Grid.Column="3" Clicked="OnOperatorClicked" BackgroundColor="{StaticResource ActivumBlueGreen}" FontFamily="Verdana" TextColor="White"/>
        </Grid>

    </VerticalStackLayout>
</ContentPage>