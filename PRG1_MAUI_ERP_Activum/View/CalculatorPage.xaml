<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PRG1_MAUI_ERP_Activum.View.CalculatorPage"
             BackgroundColor="{StaticResource PageBackground}"
             Title="Kalkylator">
    

    <Grid RowDefinitions="Auto,*,Auto,Auto" Padding="20">
        <Grid Grid.Row="0" BackgroundColor="{StaticResource ActivumBlueGreen}" HeightRequest="80" Padding="20">
            <Label Text="Miniräknare" VerticalOptions="Center" 
                   TextColor="{StaticResource ActivumWhite}" FontSize="25"/>
        </Grid>

        <VerticalStackLayout Grid.Row="1" Spacing="5" VerticalOptions="End" Padding="20,0,20,20">
            <Label x:Name="LiveInputLabel" Text="" 
                   FontSize="18" TextColor="{StaticResource SecondaryText}" 
                   HorizontalTextAlignment="End"/>
            
            <Label x:Name="HistoryLabel" Text="" 
                   FontSize="16" TextColor="{StaticResource SecondaryText}" 
                   HorizontalTextAlignment="End" 
                   Padding="10"/>
            
            
            <Entry x:Name="Display" 
                   Text="0" FontSize="40"  HorizontalTextAlignment="End" 
                   BackgroundColor="{StaticResource ActivumWhite}" TextColor="{StaticResource ActivumBlack}"
                   IsReadOnly="True"/>
            
            
        </VerticalStackLayout>

        <Grid Grid.Row="2" ColumnDefinitions="*,*,*,*" RowDefinitions="*,*,*,*,*" ColumnSpacing="15" RowSpacing="15">
            <Button Grid.Row="0" Grid.Column="0" Text="C" BackgroundColor="{StaticResource ActivumBlueGreen}" TextColor="{StaticResource ActivumWhite}" Clicked="OnClearClicked"/>
            <Button Grid.Row="0" Grid.Column="1" Text="CE" BackgroundColor="{StaticResource ActivumBlueGreen}" TextColor="{StaticResource ActivumWhite}" Clicked="OnClearEntryClicked"/>
            <Button Grid.Row="0" Grid.Column="2" Text="⌫" BackgroundColor="{StaticResource ActivumBlueGreen}" TextColor="{StaticResource ActivumWhite}" Clicked="OnBackspaceClicked"/>
            <Button Grid.Row="0" Grid.Column="3" Text="÷" BackgroundColor="{StaticResource ActivumBlueGreen}" TextColor="{StaticResource ActivumWhite}" Clicked="OnOperatorClicked"/>

            <Button Grid.Row="1" Grid.Column="0" Text="7" BackgroundColor="{StaticResource ActivumWhite}" TextColor="{StaticResource ActivumBlack}" Clicked="OnNumberClicked"/>
            <Button Grid.Row="1" Grid.Column="1" Text="8" BackgroundColor="{StaticResource ActivumWhite}" TextColor="{StaticResource ActivumBlack}" Clicked="OnNumberClicked"/>
            <Button Grid.Row="1" Grid.Column="2" Text="9" BackgroundColor="{StaticResource ActivumWhite}" TextColor="{StaticResource ActivumBlack}" Clicked="OnNumberClicked"/>
            <Button Grid.Row="1" Grid.Column="3" Text="×" BackgroundColor="{StaticResource ActivumBlueGreen}" TextColor="{StaticResource ActivumWhite}" Clicked="OnOperatorClicked"/>

            <Button Grid.Row="2" Grid.Column="0" Text="4" BackgroundColor="{StaticResource ActivumWhite}" TextColor="{StaticResource ActivumBlack}" Clicked="OnNumberClicked"/>
            <Button Grid.Row="2" Grid.Column="1" Text="5" BackgroundColor="{StaticResource ActivumWhite}" TextColor="{StaticResource ActivumBlack}" Clicked="OnNumberClicked"/>
            <Button Grid.Row="2" Grid.Column="2" Text="6" BackgroundColor="{StaticResource ActivumWhite}" TextColor="{StaticResource ActivumBlack }" Clicked="OnNumberClicked"/>
            <Button Grid.Row="2" Grid.Column="3" Text="-" BackgroundColor="{StaticResource ActivumBlueGreen}" TextColor="{StaticResource ActivumWhite}" Clicked="OnOperatorClicked"/>

            <Button Grid.Row="3" Grid.Column="0" Text="1" BackgroundColor="{StaticResource ActivumWhite}" TextColor="{StaticResource ActivumBlack}" Clicked="OnNumberClicked"/>
            <Button Grid.Row="3" Grid.Column="1" Text="2" BackgroundColor="{StaticResource ActivumWhite}" TextColor="{StaticResource ActivumBlack}" Clicked="OnNumberClicked"/>
            <Button Grid.Row="3" Grid.Column="2" Text="3" BackgroundColor="{StaticResource ActivumWhite}" TextColor="{StaticResource ActivumBlack}" Clicked="OnNumberClicked"/>
            <Button Grid.Row="3" Grid.Column="3" Text="+" BackgroundColor="{StaticResource ActivumBlueGreen}" TextColor="{StaticResource ActivumWhite}" Clicked="OnOperatorClicked"/>

            <Button Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Text="0" BackgroundColor="{StaticResource ActivumWhite}" TextColor="{StaticResource ActivumBlack}" Clicked="OnNumberClicked"/>
            <Button Grid.Row="4" Grid.Column="2" Text="." BackgroundColor="{StaticResource ActivumWhite}" TextColor="{StaticResource ActivumBlack}" Clicked="OnDecimalClicked"/>
            <Button Grid.Row="4" Grid.Column="3" Text="=" BackgroundColor="{StaticResource ActivumBlueGreen}" TextColor="{StaticResource ActivumWhite}" Clicked="OnEqualsClicked"/>
        </Grid>
    </Grid>
</ContentPage>
