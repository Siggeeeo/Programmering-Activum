<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PRG1_MAUI_ERP_Activum.View.CalculatorPage"
             BackgroundColor="#1E1E2E">

    <Grid RowDefinitions="Auto,*,Auto" Padding="20">
        <Grid Grid.Row="0" BackgroundColor="#0F3460" HeightRequest="80" Padding="20">
            <Label Text="Miniräknare" VerticalOptions="Center" 
                   TextColor="White" FontSize="24" FontAttributes="Bold"/>
        </Grid>

        <VerticalStackLayout Grid.Row="1" Spacing="5" VerticalOptions="End" Padding="20,0,20,20">
            
            
            <Label x:Name="LiveInputLabel" Text="" 
                   FontSize="18" TextColor="Gray" 
                   HorizontalTextAlignment="End"
                   
                   
                   />
            
            <Label x:Name="HistoryLabel" Text="" 
                   FontSize="16" TextColor="LightGray" 
                   HorizontalTextAlignment="End" 
                   BackgroundColor="#2A2A3E" Padding="10"
                   
                   />
            
            
            <Entry x:Name="Display" 
                   Text="0" FontSize="40" HorizontalTextAlignment="End"
                   BackgroundColor="#2A2A3E" TextColor="White"
                   PlaceholderColor="LightGray" IsReadOnly="True" Padding="15"/>
            
            
        </VerticalStackLayout>

        <Grid Grid.Row="2" ColumnDefinitions="*,*,*,*" RowDefinitions="*,*,*,*,*" ColumnSpacing="12" RowSpacing="12">
            <Button Grid.Row="0" Grid.Column="0" Text="C" BackgroundColor="#4A5568" TextColor="White" Clicked="OnClearClicked"/>
            <Button Grid.Row="0" Grid.Column="1" Text="CE" BackgroundColor="#4A5568" TextColor="White" Clicked="OnClearEntryClicked"/>
            <Button Grid.Row="0" Grid.Column="2" Text="⌫" BackgroundColor="#4A5568" TextColor="White" Clicked="OnBackspaceClicked"/>
            <Button Grid.Row="0" Grid.Column="3" Text="÷" BackgroundColor="#4299E1" TextColor="White" Clicked="OnOperatorClicked"/>

            <Button Grid.Row="1" Grid.Column="0" Text="7" BackgroundColor="#2D3748" TextColor="White" Clicked="OnNumberClicked"/>
            <Button Grid.Row="1" Grid.Column="1" Text="8" BackgroundColor="#2D3748" TextColor="White" Clicked="OnNumberClicked"/>
            <Button Grid.Row="1" Grid.Column="2" Text="9" BackgroundColor="#2D3748" TextColor="White" Clicked="OnNumberClicked"/>
            <Button Grid.Row="1" Grid.Column="3" Text="×" BackgroundColor="#4299E1" TextColor="White" Clicked="OnOperatorClicked"/>

            <Button Grid.Row="2" Grid.Column="0" Text="4" BackgroundColor="#2D3748" TextColor="White" Clicked="OnNumberClicked"/>
            <Button Grid.Row="2" Grid.Column="1" Text="5" BackgroundColor="#2D3748" TextColor="White" Clicked="OnNumberClicked"/>
            <Button Grid.Row="2" Grid.Column="2" Text="6" BackgroundColor="#2D3748" TextColor="White" Clicked="OnNumberClicked"/>
            <Button Grid.Row="2" Grid.Column="3" Text="-" BackgroundColor="#4299E1" TextColor="White" Clicked="OnOperatorClicked"/>

            <Button Grid.Row="3" Grid.Column="0" Text="1" BackgroundColor="#2D3748" TextColor="White" Clicked="OnNumberClicked"/>
            <Button Grid.Row="3" Grid.Column="1" Text="2" BackgroundColor="#2D3748" TextColor="White" Clicked="OnNumberClicked"/>
            <Button Grid.Row="3" Grid.Column="2" Text="3" BackgroundColor="#2D3748" TextColor="White" Clicked="OnNumberClicked"/>
            <Button Grid.Row="3" Grid.Column="3" Text="+" BackgroundColor="#4299E1" TextColor="White" Clicked="OnOperatorClicked"/>

            <Button Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Text="0" BackgroundColor="#2D3748" TextColor="White" Clicked="OnNumberClicked"/>
            <Button Grid.Row="4" Grid.Column="2" Text="." BackgroundColor="#2D3748" TextColor="White" Clicked="OnDecimalClicked"/>
            <Button Grid.Row="4" Grid.Column="3" Text="=" BackgroundColor="#10B981" TextColor="White" Clicked="OnEqualsClicked"/>
        </Grid>
    </Grid>
</ContentPage>
