<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PRG1_MAUI_ERP_Activum.View.SalaryPage"
             BackgroundColor="{StaticResource PageBackground}"
             Title="Lön och Bonus">

    <Grid RowDefinitions="Auto, *">
        <Grid Grid.Row="0" BackgroundColor="{StaticResource ActivumBlueGreen}" HeightRequest="80" Padding="25">
            <Label Text="Lön och Bounus" VerticalOptions="Center" TextColor="{StaticResource ActivumWhite}" FontSize="25"></Label>
        </Grid>

        <ScrollView Grid.Row="1" Padding="20">
            <VerticalStackLayout Spacing="20">

                <Label Text="Räkna ut lön och semesterersättning" FontSize="20" TextColor="{StaticResource PrimaryText}"/>

                <VerticalStackLayout Spacing="10">
                    <Label Text="Månadens försäljning (kr):" TextColor="{StaticResource SecondaryText}"/>
                    <Entry x:Name="SalesEntry"
                           Keyboard="Numeric"
                           Placeholder="T.ex. 10000 kr"
                           TextColor="{StaticResource PrimaryText}">
                    </Entry>

                    <Label Text="Antal arbetande månader i år (max 11):" TextColor="{StaticResource SecondaryText}"/>
                    <Entry x:Name="MonthsEntry"
                           Keyboard="Numeric"
                           Placeholder="T.ex. 8"
                           TextColor="{StaticResource PrimaryText}">
                        
                    </Entry>

                    <Button Text="Beräkna lön"
                            BackgroundColor="{StaticResource ActivumBlueGreen}"
                            TextColor="{StaticResource ActivumWhite}"
                            Margin="0,10,0,0"
                            Clicked="OnCalculateSalaryClicked">
                        
                    </Button>
                </VerticalStackLayout>

                <Frame BackgroundColor="{StaticResource ActivumBlueGreen}" Padding="15" Margin="0,10,0,0">
                    <Label x:Name="ResultLabel" Text="Fyll i dina uppgifter för att se lönespecifikation." TextColor="{StaticResource ActivumWhite}" FontSize="18"></Label>
                </Frame>

                <Label Text="Tidigare utbetalningar" FontSize="20" TextColor="{StaticResource PrimaryText}" Margin="0,20,0,0"></Label>

                <Grid ColumnDefinitions="*, Auto" Padding="16" BackgroundColor = "{StaticResource ActivumWhite}">
                    <Label Grid.Column="0" Text="2026-03-12" TextColor="{StaticResource PrimaryText}" VerticalOptions="Center"></Label>
                    <Label Grid.Row="1" Text="24 100 kr" TextColor="{StaticResource PrimaryText}" VerticalOptions="Center"></Label>
                </Grid>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
