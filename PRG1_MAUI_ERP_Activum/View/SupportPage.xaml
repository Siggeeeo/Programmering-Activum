<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PRG1_MAUI_ERP_Activum.View.SupportPage"
             Title="Support">

    <Grid RowDefinitions="Auto, *, Auto" Padding="20" BackgroundColor="{StaticResource White}">

        <VerticalStackLayout Grid.Row="0" Spacing="10" Margin="0,0,0,20">
            <Label Text="Hjälp och Support"
                   FontSize="32"
                   FontAttributes="Bold"
                   TextColor="{StaticResource Primary}"
                   HorizontalOptions="Center"/>
            <BoxView HeightRequest="2"
                     Color="{StaticResource Primary}"
                     WidthRequest="150"
                     HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Spacing="20" Padding="10">
                <Label Text="Har du stött på ett problem? Kontakta vår IT support så hjälper vi dig så snabbt som möjligt"
                       HorizontalTextAlignment="Center"
                       FontSize="16"
                       TextColor="{StaticResource Black}"
                       Margin="0,0,0,10"/>

                <VerticalStackLayout Spacing="8">
                    <Label Text="Ämne" FontSize="14" TextColor="{StaticResource Primary}" FontAttributes="Bold" />
                    <Entry Placeholder="Vad gäller ärendet?" 
                           BackgroundColor="#F5F5F5" 
                           TextColor="{StaticResource Black}"/>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="8">
                    <Label Text="Meddelande" FontSize="14" TextColor="{StaticResource Primary}" FontAttributes="Bold" />
                    <Editor Placeholder="Beskriv problemet här" 
                            HeightRequest="150" 
                            BackgroundColor="#F5F5F5" 
                            TextColor="{StaticResource Black}"/>
                </VerticalStackLayout>

                <Button Text="Skicka Ärende" 
                        BackgroundColor="{StaticResource Primary}" 
                        TextColor="White" 
                        CornerRadius="10"
                        HeightRequest="50"
                        Margin="0,10,0,0"/>
            </VerticalStackLayout>
        </ScrollView>

        <VerticalStackLayout Grid.Row="2" Spacing="2" Margin="0,10,0,5" HorizontalOptions="Center">
            <Label Text="IT-avdelningen: support@activum.se"
                   FontSize="12"
                   TextColor="{StaticResource Black}"
                   HorizontalOptions="Center"/>
            <Label Text="Öppet vardagar 08:00 - 17:00"
                   FontSize="12"
                   TextColor="{StaticResource Black}" 
                   HorizontalOptions="Center"/>
            
        </VerticalStackLayout>

    </Grid>
</ContentPage>