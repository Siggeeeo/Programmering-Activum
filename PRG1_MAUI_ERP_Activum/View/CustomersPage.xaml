<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PRG1_MAUI_ERP_Activum.View.CustomersPage"
             BackgroundColor="{StaticResource PageBackground}"
             Title="Kunder">

    <Grid RowDefinitions="Auto, Auto, *">
        <Grid Grid.Row="0" BackgroundColor="{StaticResource ActivumBlueGreen}" HeightRequest="80" Padding="20">
            <Label Text="Kundregister" VerticalOptions="Center" TextColor="{StaticResource ActivumWhite}" FontSize="25"></Label>
        </Grid>

        <Frame Grid.Row="1" Margin="20,10" Padding="15">
            <VerticalStackLayout Spacing="10">
                <Label Text="Lägg till ny kund" TextColor="{StaticResource ActivumBlueGreen}"></Label>
                <Entry x:Name="CustomerNameEntry" Placeholder="Företagsnamn / Kundnamn"></Entry>
                <Entry x:Name="CustomerEmailEntry" Placeholder="E-Postadress" Keyboard="Email"></Entry>
                <Button Text="Spara Kund"
                        BackgroundColor="{StaticResource ActivumBlueGreen}"
                        TextColor="{StaticResource ActivumWhite}"
                        Clicked="OnAddCustomerClicked"></Button>
            </VerticalStackLayout>
        </Frame>

        <CollectionView Grid.Row="2" x:Name="CustomerListView" Margin="20,0">
            <CollectionView.Header>
                <Label Text="Aktiva Kunder" FontSize="18" Margin="0,10"></Label>
            </CollectionView.Header>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,5" Padding="15" BackgroundColor="{StaticResource ActivumWhite}" BorderColor="{StaticResource ActivumWhite}">
                        <HorizontalStackLayout Spacing="15">
                            <VerticalStackLayout>
                                <Label Text="{Binding Name}" FontSize="16" TextColor="{StaticResource ActivumBlack}"></Label>
                                <Label Text="{Binding Email}" FontSize="13" TextColor="{StaticResource SecondaryText}"></Label>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
    
</ContentPage>