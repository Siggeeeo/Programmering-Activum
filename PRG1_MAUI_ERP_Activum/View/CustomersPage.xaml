<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PRG1_MAUI_ERP_Activum.View.CustomersPage"
             Title="Kundregister">
    <VerticalStackLayout Padding="20" Spacing="15">

        <SearchBar Placeholder="Sök på namn eller kundtyp (Privat/Företag)"
                   TextChanged="OnsearchTextChanged"/>

        <CollectionView ItemsSource="{Binding Customers}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0, 0, 0, 10" Padding="15" BackgroundColor="White">
                        <VerticalStackLayout Spacing="5">

                            <Label Text="{Binding FullName}" FontAttributes="Bold" FontSize="18" TextColor="Black"/>

                            <Label Text="{Binding Email}" TextColor="Gray" FontSize="14"/>
                            <Label Text="{Binding CustomerType}" TextColor="Blue" FontSize="14"/>


                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
</ContentPage>